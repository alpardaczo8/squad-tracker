<!DOCTYPE html>
<html lang="en">
  <head>
    <%- include('partials/head', { title: 'Players' }) %>
  </head>
  <body>
    <%- include('partials/navbar') %>

    <main class="container">
      <h1 class="page-title">Squad</h1>

      <div class="card">
        <h2 class="card-title">Add Player</h2>
        <form action="/addPlayer" method="POST" class="form">
          <div class="form-row">
            <input type="text" name="name" placeholder="Player name" class="input" required>
            <input type="text" name="position" placeholder="Position" class="input" required>
            <input type="date" name="date_of_birth" class="input">
            <input type="text" name="nationality" placeholder="Nationality" class="input">
            <button type="submit" class="btn">Add Player</button>
          </div>
        </form>
      </div>

      <div class="card">
        <h2 class="card-title">Players</h2>
        <table class="table">
          <thead>
            <tr>
              <th>Name</th>
              <th>Position</th>
            </tr>
          </thead>
          <tbody>
            <% players.forEach(player => { %>
              <tr>
                <td><%= player.name %></td>
                <td><%= player.position %></td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    </main>
  </body>
</html>